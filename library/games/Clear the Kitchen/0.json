              "beginner",
              "advanced"
            ],
            "label": "Board",
            "variable": "board"
          }
        ],
        "header": "New Game",
        "confirmButtonText": "New Game",
        "cancelButtonText": "Resume Game"
      },
      {
        "func": "RECALL",
        "holder": "mouseHolder"
      },
      {
        "func": "RESET"
      },
      {
        "func": "SET",
        "collection": [
          "beginnerBoard",
          "advancedBoard"
        ],
        "property": "display",
        "value": false
      },
      {
        "func": "SET",
        "collection": [
          "${board}Board"
        ],
        "property": "display"
      },
