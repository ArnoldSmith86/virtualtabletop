    "height": 150,
    "layer": -3,
    "z": 129,
    "movable": false,
    "movableInEdit": false,
    "css": "font-size: 25px; ",
    "text": "INPUT is used to prompt a user to enter data that can be stored in a variable and acted upon. At its most basic form, it can serve as a confirmation prompt. Unless the user presses the continue/go button, the routine will not continue. Each of the examples below demonstrates 8 of the 9 possible field types of INPUT (the 'choose' type is in another variant of this tutorial). They are each presented in their most basic and default form first, followed by an example with changes to the parameters when the parameter has additional options. The result (the variable used by routines) is displayed on the button."
  },
  "button1": {
    "type": "button",
    "id": "button1",
    "x": 45,
    "y": 250,
    "z": 22838,
    "text": true,
    "clickRoutine": [
      {
        "func": "INPUT",
        "fields": [
          {
            "type": "checkbox",
            "label": "Check or uncheck this box",
            "variable": "checkbox",
            "value": "${PROPERTY text}"
          }
        ]
      },
      {
        "func": "SET",
        "collection": "thisButton",
        "property": "text",
        "value": "${checkbox}"
      }
    ]
  },
